# Database Configuration
# PostgreSQL is used for structured and relational tables (Users, Jobs, Applications, Interviews)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hr_system

# MongoDB is used for unstructured data, storing resume PDF/DOCX files as GridFS blobs
MONGODB_URL=mongodb://localhost:27017/hr_system_resumes
MONGODB_DB_NAME=hr_system_resumes

# Security Configuration
# Secret key used for signing JWT access and refresh tokens
SECRET_KEY=supersecretjwtkeythatshouldbechangedinproduction12345!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
